Example 1:
Input: s = "()"
Output: true

#implementation
class Solution {
    public boolean isValid(String s) {
        boolean changed;
        do{
         String prev =s;
         changed = false;
        
         s = s.replace("()", "")
                 .replace("{}", "")
                 .replace("[]", "");
                 if(!s.equals(prev)){
                    changed=true;
                 }
        }
        while(changed);
        return s.isEmpty();
        }


#implemtation

class Solution {
    public boolean isValid(String s) {
        Stack<Character> st = new Stack<>();
        for(char ch:s.toCharArray())
        {
            if(ch=='('||ch=='{'||ch=='[')
            {
                st.push(ch);
            }
            else{
                if(st.isEmpty())
                {
                    return false;
                }
                    if((st.peek()=='('&&ch==')') || (st.peek()=='{'&&ch=='}')||(st.peek()=='['&&ch==']'))
                    {
                        st.pop();
                    }
                    else
                    {
                        return false;
                    }
                }
            }
            return st.isEmpty();
        }      
    }
       

       
     

        
